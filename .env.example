# Настройка провайдеров — опциональна.
# Ключи можно ввести прямо в TUI при первом запуске (команда /provider),
# либо задать здесь. Переменные ниже — override над preferences.json.

# Провайдер и модель (опционально). При отсутствии — выбор в TUI.
# Допустимые значения: anthropic | openai | gemini | groq |
#   openrouter | xai | deepseek | custom
# BARTENDER_PROVIDER=anthropic
# BARTENDER_MODEL=claude-3-5-haiku-latest

# Ключи провайдеров (получить: см. ссылки в TUI при настройке)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Свой OpenAI-compat endpoint
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=https://api.example.com/v1

# Легаси (opencode-go) — маппится на custom при первом запуске.
# OPENCODE_GO_API_KEY=
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
