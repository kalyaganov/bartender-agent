# Провайдер и модель (опционально).
# Если BARTENDER_PROVIDER не задан — при старте появится экран выбора
# (или используется сохранённый выбор из ~/.homeagent/preferences.json).
BARTENDER_PROVIDER=opencode-go
BARTENDER_MODEL=deepseek-v4-pro

# OpenCode Go — https://opencode.ai/docs/go/
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# Альтернативные провайдеры
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
