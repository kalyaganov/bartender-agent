{
  "name": "bartender-agent",
  "version": "0.2.0",
  "description": "Бармен Виктор — AI character agent in TUI (TypeScript + Ink)",
  "type": "module",
  "license": "MIT",
  "author": "Alexey Kalyaganov <aa.kalyaganov@yandex.ru>",
  "homepage": "https://github.com/kalyaganov/bartender-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalyaganov/bartender-agent.git"
  },
  "bugs": {
    "url": "https://github.com/kalyaganov/bartender-agent/issues"
  },
  "keywords": [
    "cli",
    "tui",
    "ink",
    "react",
    "character-agent",
    "ai",
    "llm",
    "roleplay",
    "game",
    "bartender",
    "terminal"
  ],
  "main": "dist/index.js",
  "bin": {
    "bartender": "bin/bartender.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "start": "tsx src/index.tsx",
    "build": "esbuild src/index.tsx --bundle --platform=node --format=esm --target=node18 --packages=external --jsx=automatic --outfile=dist/index.js --log-level=warning",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "openai": "^6.44.0",
    "react": "^18.3.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.31",
    "esbuild": "^0.28.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
